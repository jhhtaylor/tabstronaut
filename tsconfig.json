{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "outDir": "out",
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "strict": true,
    "types": ["mocha", "node"]
  },
  "exclude": ["node_modules", ".vscode-test", "webviews", "webpack.config.ts", "eslint.config.ts"]
}
